<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScCestinator.Views.InstallationSelectionDialog"
        Title="Výběr instalace Star Citizen"
        Width="700"
        Height="350"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top"
                   Text="Bylo nalezeno více instalací Star Citizen. Vyber jednu:"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">

            <Button Content="Zrušit"
                    Width="100"
                    Click="Cancel_Click"/>

            <Button Content="OK"
                    Width="100"
                    Click="Ok_Click"/>
        </StackPanel>

        <ListBox x:Name="InstallationsListBox"/>
    </DockPanel>
</Window>
