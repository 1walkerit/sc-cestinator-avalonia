<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScCestinator.ViewModels"
        x:Class="ScCestinator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SC Češtinátor Linux"
        Width="900"
        Height="600"
        MinWidth="800"
        MinHeight="500">

    <Window.Styles>
        <Style Selector="Button.link-button">
            <Setter Property="Background" Value="#66202A36" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Button.link-button:pointerover">
            <Setter Property="Background" Value="#88405A78" />
        </Style>
    </Window.Styles>

    <Grid Margin="0">
        <Image Source="avares://ScCestinator/Assets/background.jpg"
               Stretch="UniformToFill"
               ZIndex="0" />

        <Border Background="#55FFFFFF"
                ZIndex="1" />

        <Grid ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            

            <!-- Header -->
            <Border Grid.Row="0" Background="#CC1E88E5" Padding="20,12">
                <Grid>
                    <TextBlock Text="SC Češtinátor Linux"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AppVersion}"
                               FontSize="11"
                               Foreground="White"
                               Opacity="0.85"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" ColumnDefinitions="*,240" ColumnSpacing="16" Margin="20">
                <ScrollViewer Grid.Column="0">
                    <StackPanel Spacing="20">

                <!-- Star Citizen Path Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Padding="15"
                        Margin="10">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Cesta ke Star Citizen" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding InputPath}"
                                     PlaceholderText="Zadejte cestu nebo vyberte složku..."
                                     VerticalContentAlignment="Center"
                                     Height="36" />
                            <Button Grid.Column="1" 
                                    Content="Vybrat složku" 
                                    Command="{Binding BrowseFolderCommand}"
                                    Margin="10,0,0,0"
                                    Height="36"
                                    Padding="15,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Versions Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Informace o verzi" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Lokální verze:" 
                                       FontWeight="Medium"
                                       Margin="0,0,10,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding LocalVersion}"
                                       Margin="0,0,0,8" />
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Online verze:" 
                                       FontWeight="Medium"
                                       Margin="0,0,10,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding OnlineVersion}" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Status:"
                                       FontWeight="Medium"
                                       Margin="0,8,10,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{Binding StatusBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Spacing="10" HorizontalAlignment="Stretch">
                    <Button Content="Instalovat / Aktualizovat češtinu"
                            Command="{Binding InstallCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#007ACC"
                            Foreground="White"
                            FontWeight="Bold"
                            Height="48"
                            FontSize="16"
                            Classes="accent" />

                    <Button Content="Odinstalovat češtinu"
                            Command="{Binding UninstallCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#AA4444"
                            Foreground="White"
                            Height="48"
                            FontSize="16"
                            FontWeight="SemiBold" />
                </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Background="#BB101820"
                        BoxShadow="0 6 18 #30000000">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Užitečné odkazy"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,6" />

                        <Button Classes="link-button"
                                Content="CZ lokalizace"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://github.com/JarredSC/Star-Citizen-CZ-lokalizace"
                                HorizontalAlignment="Stretch" />

                        <Button Classes="link-button"
                                Content="Star Citizen web"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://robertsspaceindustries.com"
                                HorizontalAlignment="Stretch" />

                        <Button Classes="link-button"
                                Content="RSI Account / Hangar"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://robertsspaceindustries.com/account/pledges"
                                HorizontalAlignment="Stretch" />

                        <Button Classes="link-button"
                                Content="Spectrum"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://robertsspaceindustries.com/spectrum/community/SC"
                                HorizontalAlignment="Stretch" />

                        <Button Classes="link-button"
                                Content="Issue Council"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://issue-council.robertsspaceindustries.com"
                                HorizontalAlignment="Stretch" />

                        <Button Classes="link-button"
                                Content="Launcher ke stažení"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://robertsspaceindustries.com/download"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</Window>
