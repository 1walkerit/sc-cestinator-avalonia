<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScCestinator.ViewModels"
        x:Class="ScCestinator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SC CZ Toolkit"
        Icon="/Assets/icon.png"
        Width="1000"
        Height="560"
        MinWidth="1000"
        MinHeight="560">

    <Window.Styles>

<Style Selector="Button">
    <Setter Property="Cursor" Value="Hand" />
</Style>
        <!-- Download button custom style -->
        <Style Selector="Button.download-button">
            <Setter Property="Background" Value="#FFFFB020"/>
            <Setter Property="Foreground" Value="#FF08111F"/>
            <Setter Property="BorderBrush" Value="#FFFFD27A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.download-button:pointerover">
            <Setter Property="Background" Value="#FFE6A000"/>
            <Setter Property="Foreground" Value="#FF08111F"/>
            <Setter Property="BorderBrush" Value="#FFFFE0A0"/>
        </Style>
        <Style Selector="Button.download-button:pressed">
            <Setter Property="Background" Value="#FF7A4A00"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFFFE0A0"/>
        </Style>
        <Style Selector="Button.download-button:disabled">
            <Setter Property="Background" Value="#5A5F6875"/>
            <Setter Property="Foreground" Value="#B8F4F6FA"/>
            <Setter Property="BorderBrush" Value="#707B8798"/>
            <Setter Property="Opacity" Value="0.72"/>
        </Style>
        <Style Selector="Button.download-button:disabled:pointerover">
            <Setter Property="Background" Value="#5A5F6875"/>
            <Setter Property="Foreground" Value="#B8F4F6FA"/>
            <Setter Property="BorderBrush" Value="#707B8798"/>
        </Style>

        <Style Selector="Button.browse-button">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.browse-button:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>
        <Style Selector="Button.browse-button:disabled">
            <Setter Property="Background" Value="#5A5F6875" />
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="Button.browse-button:disabled:pointerover">
            <Setter Property="Background" Value="#5A5F6875" />
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
        </Style>

        <Style Selector="Button.link-button">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.link-button:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>
        <Style Selector="Button.link-button:disabled">
            <Setter Property="Background" Value="#5A5F6875" />
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="Button.link-button:disabled:pointerover">
            <Setter Property="Background" Value="#5A5F6875" />
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
        </Style>

        <Style Selector="Button.link-compact">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.link-compact:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>

        <Style Selector="Button.action-primary">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.action-primary:pointerover">
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>

        <Style Selector="Button.action-danger">
            <Setter Property="Background" Value="#8B2E2E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.action-danger:pointerover">
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="Background" Value="#A63A3A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>
        <Style Selector="Button.action-primary:pressed">
    <Setter Property="Background" Value="#0D47A1" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="#BBFFFFFF" />
    <Setter Property="Opacity" Value="0.92" />
</Style>

<Style Selector="Button.action-danger:pressed">
    <Setter Property="Background" Value="#7F1D1D" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="#BBFFFFFF" />
    <Setter Property="Opacity" Value="0.92" />
</Style>

        <Style Selector="Button.action-primary:disabled, Button.action-danger:disabled">
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
        </Style>
        <Style Selector="Button.action-primary:disabled">
            <Setter Property="Background" Value="#5A5F6875" />
        </Style>
        <Style Selector="Button.action-danger:disabled">
            <Setter Property="Background" Value="#5A5F6875" />
        </Style>
        <Style Selector="Button.action-primary:disabled:pointerover, Button.action-danger:disabled:pointerover">
            <Setter Property="Foreground" Value="#B8F4F6FA" />
            <Setter Property="BorderBrush" Value="#707B8798" />
        </Style>
        <Style Selector="Button.action-primary:disabled:pointerover">
            <Setter Property="Background" Value="#5A5F6875" />
        </Style>
        <Style Selector="Button.action-danger:disabled:pointerover">
            <Setter Property="Background" Value="#5A5F6875" />
        </Style>

        <!-- Dark transparent glass look for header menu and submenu items -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="#CC1A1A1A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#CC0B1A2B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="#AA1B2F45" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="MenuItem:open">
            <Setter Property="Background" Value="#AA1B2F45" />
        </Style>
        <Style Selector="MenuItem /template/ Popup Border">
            <Setter Property="Background" Value="#CC0B1A2B" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="MenuItem /template/ Popup ScrollViewer">
            <Setter Property="Background" Value="#CC0B1A2B" />
        </Style>
        <Style Selector="MenuItem /template/ Popup MenuItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#CC0B1A2B" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Styles>

    <Grid Margin="0">
        <Image Source="avares://ScCestinator/Assets/background.png"
               Stretch="UniformToFill"
               ZIndex="0" />

        <Border Background="#55FFFFFF"
                ZIndex="1" />

        <Grid ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#CC1E88E5" Padding="20,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="16"
                                VerticalAlignment="Center">
                        <TextBlock Text="SC CZ Toolkit"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />

                        <Menu HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              Foreground="White">
                            <MenuItem Header="Odkazy"
                                      FontWeight="Bold"
                                      Background="#AA0B1A2B"
                                      Foreground="White">

                                <MenuItem Header="Star Citizen Česko Slovensko">
                                    <MenuItem Header="Organizace" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/orgs/CZSK" />
                                    <MenuItem Header="Připojit se na náš Discord" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.gg/scczsk" />
                                    <MenuItem Header="Kanál s návody" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1019872713713659965" />
                                    <MenuItem Header="Diskuze k překladu Star Citizen" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1162077785376964719" />
                                    <MenuItem Header="Co je to PTU a jak funguje" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1139302959239397446" />
                                    <MenuItem Header="Komunitní mapa hráčů" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.google.com/maps/d/u/2/viewer?mid=1D-N794_RD7wsDt5AayWjf0QJ82fwe0o&amp;hl=cs&amp;ll=49.53699999999999%2C16.512000000000018&amp;z=8" />
                                    <MenuItem Header="Star Citizen CZ/SK Wiki" Command="{Binding OpenUrlCommand}" CommandParameter="https://wiki.theravens.cz/star-citizen/index.php/Hlavn%C3%AD_strana" />
                                    <MenuItem Header="CZ/SK Bar Citizen" Command="{Binding OpenUrlCommand}" CommandParameter="https://barcitizen.star-citizen.cz/" />
                                    <MenuItem Header="Náš Facebook" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.facebook.com/StarCitizenCzSk" />
                                    <MenuItem Header="Náš Youtube" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.youtube.com/c/StarCitizen%C4%8Cesko-Slovensko" />
                                    <MenuItem Header="Anonymní feedback" Command="{Binding OpenUrlCommand}" CommandParameter="https://feedback.star-citizen.cz/" />
                                </MenuItem>

                                <MenuItem Header="Roberts Space Industries">
                                    <MenuItem Header="Můj RSI účet" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/settings" />
                                    <MenuItem Header="Můj RSI hangár" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/pledges" />
                                    <MenuItem Header="Herní balíky" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/store/pledge/browse/game-packages" />
                                    <MenuItem Header="Samostatné lodě" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/pledge/ships" />
                                    <MenuItem Header="Spectrum" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/spectrum/community/SC" />
                                    <MenuItem Header="Issue Council" Command="{Binding OpenUrlCommand}" CommandParameter="https://issue-council.robertsspaceindustries.com/" />
                                    <MenuItem Header="Telemetrie" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/telemetry" />
                                    <MenuItem Header="Stav RSI služeb" Command="{Binding OpenUrlCommand}" CommandParameter="https://status.robertsspaceindustries.com/" />
                                    <MenuItem Header="Plán vývoje" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/roadmap/release-view" />
                                    <MenuItem Header="Financování vývoje" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/funding-goals" />
                                    <MenuItem Header="Hvězdná mapa" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/starmap" />
                                    <MenuItem Header="Tabulka náhradních lodí" Command="{Binding OpenUrlCommand}" CommandParameter="https://support.robertsspaceindustries.com/hc/en-us/articles/360003093114-Loaner-Ship-Matrix" />
                                    <MenuItem Header="Oprava herní postavy" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/reset" />
                                    <MenuItem Header="Kopírovat herní postavu do PTU" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/copy/ptu" />
                                </MenuItem>

                                <MenuItem Header="Nástroje a komunitní weby">
                                    <MenuItem Header="Erkul" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.erkul.games/" />
                                    <MenuItem Header="CCUgame" Command="{Binding OpenUrlCommand}" CommandParameter="https://ccugame.app/" />
                                    <MenuItem Header="UEXcorp" Command="{Binding OpenUrlCommand}" CommandParameter="https://uexcorp.space/" />
                                    <MenuItem Header="Prodej a pronájem lodí ingame" Command="{Binding OpenUrlCommand}" CommandParameter="https://wiki.star-citizen.cz/N%C3%A1kup,_prodej_a_pron%C3%A1jem_lod%C3%AD" />
                                    <MenuItem Header="SC Mission Database" Command="{Binding OpenUrlCommand}" CommandParameter="https://scmdb.net/" />
                                    <MenuItem Header="SC Trade Tools" Command="{Binding OpenUrlCommand}" CommandParameter="https://sc-trade.tools/" />
                                    <MenuItem Header="SC Crafter" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.sccrafter.com/" />
                                    <MenuItem Header="SC Blueprint Finder" Command="{Binding OpenUrlCommand}" CommandParameter="https://scblueprints.app/" />
                                    <MenuItem Header="Hangar" Command="{Binding OpenUrlCommand}" CommandParameter="https://hangar.link/" />
                                    <MenuItem Header="Armory" Command="{Binding OpenUrlCommand}" CommandParameter="https://armory.thespacecoder.space/" />
                                    <MenuItem Header="VerseGuide" Command="{Binding OpenUrlCommand}" CommandParameter="https://verseguide.com/" />
                                    <MenuItem Header="Finder" Command="{Binding OpenUrlCommand}" CommandParameter="https://finder.cstone.space/" />
                                    <MenuItem Header="SC Ships Performances Viewer" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.spviewer.eu/" />
                                    <MenuItem Header="Star Citizen Characters" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.star-citizen-characters.com/" />
                                </MenuItem>

                                <MenuItem Header="Linux komunita">
                                    <MenuItem Header="Star Citizen Linux Users Group Wiki" Command="{Binding OpenUrlCommand}" CommandParameter="https://wiki.starcitizen-lug.org" />
                                    <MenuItem Header="Linux Users Group (LUG)" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/en/orgs/LUG" />
                                    <MenuItem Header="Linux Users Group Discord" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/invite/meCFYPj" />
                                    <MenuItem Header="Star Citizen Česko-Slovensko Discord" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.gg/scczsk" />
                                </MenuItem>
                            </MenuItem>


<MenuItem Header="Nástroje" FontWeight="Bold">
    <MenuItem Header="🗁 Otevřít složku hry"
              Command="{Binding OpenGameFolderCommand}" />

    <Separator />

    <MenuItem Header="🧹 Vyčistit logy"
              Command="{Binding ClearLogsCommand}" />

    <Separator />

    <MenuItem Header="🧹 Vymazat shader cache"
              Command="{Binding ClearShadersCommand}" />

    <Separator />

    <MenuItem Header="🗁 Otevřít shader cache"
              Command="{Binding OpenShaderCacheCommand}" />
</MenuItem>

<MenuItem Header="_Licence"
          Command="{Binding ShowCreditsCommand}"
          FontWeight="Bold" />


                        </Menu>


                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#AA0B1A2B"
                            Padding="10,5"
                            CornerRadius="8"
                            Margin="8,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding AppVersion}"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="White"
                                       Opacity="0.95"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding AppUpdateStatus}"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="#FFFFB020"
                                       HorizontalAlignment="Right"
                                       IsVisible="{Binding IsAppUpdateAvailable}" />
                            <Button Classes="download-button" Command="{Binding DownloadLatestVersionCommand}"
                                    IsVisible="{Binding ShowDownloadButton}"
                                    HorizontalAlignment="Right"
                                    Padding="10,4"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Background="#FFFFB020"
                                    Foreground="#FF08111F"
                                    BorderBrush="#FFFFD27A"
                                    BorderThickness="1"
                                    CornerRadius="6">


    <Button.Content>
        <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="⬇" FontSize="12"/>
            <TextBlock Text="Stáhnout"/>
            
        </StackPanel>
    </Button.Content>
</Button>
 <TextBlock
    Text="✔ Aplikace je aktuální"
    Foreground="#4CAF50"
    FontSize="11"
    FontWeight="Bold"
    HorizontalAlignment="Right"
    IsVisible="{Binding !IsAppUpdateAvailable}" />

                                    <ProgressBar Minimum="0"
             Maximum="100"
             Value="{Binding DownloadProgress}"
             IsVisible="{Binding IsDownloading}"
             Height="6"
             Margin="0,5,0,0"/>
                                    <Button Content="Otevřít složku"
                                            Command="{Binding OpenDownloadFolderCommand}"
                                            IsVisible="{Binding CanOpenDownloadFolder}"
                                            HorizontalAlignment="Right"
                                            Padding="8,3"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Background="#FF1E88E5"
                                            Foreground="White"
                                            BorderBrush="#FF90CAF9"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,5,0,0"/>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20">
                <ScrollViewer>
                    <StackPanel Spacing="20">

                        <!-- Star Citizen Path Section -->
                        <Border BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="16"
                                HorizontalAlignment="Left"
                                Background="#C00D1F31">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Cesta ke Star Citizen"
                                           Foreground="#F0FFFFFF"
                                           FontSize="18"
                                           Margin="0,0,0,2"
                                           FontWeight="SemiBold" />
                                    <Border Background="#55000000"
        BorderBrush="#33FFFFFF"
        BorderThickness="1"
        CornerRadius="8"
        Padding="8,5">
    <TextBlock Text="{Binding Status}"
               Foreground="White"
               FontSize="12"
               FontWeight="SemiBold"
               TextWrapping="Wrap" />
</Border>

                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding InputPath}"
                                             PlaceholderText="Cesta k instalaci Star Citizen..."
                                             VerticalContentAlignment="Center"
                                             Height="36" />

<Button Grid.Column="1"
        Command="{Binding BrowseFolderCommand}"
        Classes="browse-button"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center"
        Margin="10,0,0,0"
        Height="36"
        Padding="12,6">
    <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="🗁" FontSize="14"/>
        <TextBlock Text="Vybrat složku"/>
    </StackPanel>
</Button>

<Button Grid.Column="2"
        Command="{Binding FindInstallationCommand}"
        Classes="browse-button"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center"
        Margin="5,0,0,0"
        Height="36"
        Padding="12,6">
    <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="⌕" FontSize="14"/>
        <TextBlock Text="Najít instalaci hry"/>
    </StackPanel>
</Button>
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            IsVisible="{Binding HasMultipleBranches}">
                                    <TextBlock Text="Větev"
                                               VerticalAlignment="Center"
                                               Foreground="#AAFFFFFF" />
                                    <ComboBox ItemsSource="{Binding AvailableBranches}"
                                              SelectedItem="{Binding SelectedBranch}"
                                              Width="140" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Versions Section -->
                        <Border BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="18"
                                Background="#C00D1F31"
                                Width="380"
                                HorizontalAlignment="Left">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Informace o verzi"
                                           FontSize="18"
                                           Margin="0,0,0,2"
                                           FontWeight="SemiBold"
                                           Foreground="#F0FFFFFF" />

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Lokální verze:"
                                               Foreground="#AAFFFFFF"
                                               FontWeight="Medium"
                                               Margin="0,0,10,8" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding LocalVersion}"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Online verze:"
                                               Foreground="#AAFFFFFF"
                                               FontWeight="Medium"
                                               Margin="0,0,10,0" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding OnlineVersion}"
                                               Foreground="White"
                                               FontWeight="Bold" />

                                </Grid>
                            </StackPanel>
                        </Border>



                        <!-- Action Buttons -->
                        <StackPanel Orientation="Vertical"
                                    Spacing="10"
                                    HorizontalAlignment="Left"
                                    Width="380">
<Button Command="{Binding InstallCommand}"
 IsVisible="{Binding IsUpdateAvailable}"
        HorizontalAlignment="Stretch"
        Classes="action-primary"
        Height="40"
        FontSize="15"
        Padding="12,6"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center">

    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="⬇" FontSize="16"/>
        <TextBlock Text="Instalovat / aktualizovat češtinu"/>
    </StackPanel>
</Button>
                            <Border Background="#223A7A3A"
        BorderBrush="#5577CC77"
        BorderThickness="1"
        CornerRadius="8"
        Padding="12,10"
        IsVisible="{Binding !IsUpdateAvailable}">
    <TextBlock Text="Čeština je aktuální ✔"
               Foreground="#A8E6A3"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               TextAlignment="Center"/>
</Border>
<Button Command="{Binding UninstallCommand}"
        HorizontalAlignment="Stretch"
        Classes="action-danger"
        Height="40"
        FontSize="15"
        Padding="12,6"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center">

    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="🗑" FontSize="15"/>
        <TextBlock Text="Odinstalovat český překlad"/>
    </StackPanel>
</Button>              

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
