<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScCestinator.ViewModels"
        x:Class="ScCestinator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SC Češtinátor Linux"
        Width="650"
        Height="500"
        MinWidth="600"
        MinHeight="450">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColor}" Padding="20,15">
            <Grid>
                <TextBlock Text="SC Češtinátor Linux" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding AppVersion}" 
                           FontSize="11" 
                           Foreground="White"
                           Opacity="0.8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="20">

                <!-- Star Citizen Path Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Cesta ke Star Citizen" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding InputPath}"
                                     PlaceholderText="Zadejte cestu nebo vyberte složku..."
                                     VerticalContentAlignment="Center"
                                     Height="36" />
                            <Button Grid.Column="1" 
                                    Content="Vybrat složku" 
                                    Command="{Binding BrowseFolderCommand}"
                                    Margin="10,0,0,0"
                                    Height="36"
                                    Padding="15,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Versions Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Informace o verzi" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Lokální verze:" 
                                       FontWeight="Medium"
                                       Margin="0,0,10,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding LocalVersion}"
                                       Margin="0,0,0,8" />
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Online verze:" 
                                       FontWeight="Medium"
                                       Margin="0,0,10,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding OnlineVersion}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Stav" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Opacity="0.7" />
                        <TextBlock Text="{Binding Status}" 
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <Button Grid.Column="0"
                            Content="Instalovat / Aktualizovat češtinu"
                            Command="{Binding InstallCommand}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Classes="accent" />
                    
                    <Button Grid.Column="1"
                            Content="Odinstalovat češtinu"
                            Command="{Binding UninstallCommand}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            FontSize="16"
                            FontWeight="SemiBold" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
