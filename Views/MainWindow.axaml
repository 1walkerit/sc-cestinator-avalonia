<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScCestinator.ViewModels"
        x:Class="ScCestinator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SC Češtinátor Linux"
        Width="1000"
        Height="550"
        MinWidth="1000"
        MinHeight="550">

    <Window.Styles>
        <Style Selector="Button.browse-button">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.browse-button:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>
        <Style Selector="Button.browse-button:disabled">
            <Setter Property="Background" Value="#33203040" />
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="Opacity" Value="0.75" />
        </Style>
        <Style Selector="Button.browse-button:disabled:pointerover">
            <Setter Property="Background" Value="#33203040" />
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
        </Style>

        <Style Selector="Button.link-button">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.link-button:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>
        <Style Selector="Button.link-button:disabled">
            <Setter Property="Background" Value="#33203040" />
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="Opacity" Value="0.75" />
        </Style>
        <Style Selector="Button.link-button:disabled:pointerover">
            <Setter Property="Background" Value="#33203040" />
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
        </Style>

        <Style Selector="Button.link-compact">
            <Setter Property="Background" Value="#55203040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.link-compact:pointerover">
            <Setter Property="Background" Value="#88304860" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>

        <Style Selector="Button.action-primary">
            <Setter Property="Background" Value="#1B4E78" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.action-primary:pointerover">
            <Setter Property="Background" Value="#236291" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>

        <Style Selector="Button.action-danger">
            <Setter Property="Background" Value="#6D2F2F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.action-danger:pointerover">
            <Setter Property="Background" Value="#834040" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#AAFFFFFF" />
        </Style>

        <Style Selector="Button.action-primary:disabled, Button.action-danger:disabled">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
        </Style>
        <Style Selector="Button.action-primary:disabled">
            <Setter Property="Background" Value="#2E4960" />
        </Style>
        <Style Selector="Button.action-danger:disabled">
            <Setter Property="Background" Value="#4A3333" />
        </Style>
        <Style Selector="Button.action-primary:disabled:pointerover, Button.action-danger:disabled:pointerover">
            <Setter Property="Foreground" Value="#B0FFFFFF" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
        </Style>
        <Style Selector="Button.action-primary:disabled:pointerover">
            <Setter Property="Background" Value="#2E4960" />
        </Style>
        <Style Selector="Button.action-danger:disabled:pointerover">
            <Setter Property="Background" Value="#4A3333" />
        </Style>

        <!-- Dark transparent glass look for header menu and submenu items -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="#CC1A1A1A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Background" Value="#AA0B1A2B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="#CC2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="MenuItem:open">
            <Setter Property="Background" Value="#CC1A1A1A" />
        </Style>
        <Style Selector="MenuItem /template/ Popup Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border#PART_PopupBorder">
            <Setter Property="Background" Value="#CC102A52" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="MenuItem /template/ Popup MenuItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid Margin="0">
        <Image Source="avares://ScCestinator/Assets/background.png"
               Stretch="UniformToFill"
               ZIndex="0" />

        <Border Background="#55FFFFFF"
                ZIndex="1" />

        <Grid ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            

            <!-- Header -->
            <Border Grid.Row="0" Background="#CC1E88E5" Padding="20,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="16"
                                VerticalAlignment="Center">
                        <TextBlock Text="SC Češtinátor Linux"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />

                        <Menu HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              Foreground="White">
                            <MenuItem Header="Odkazy"
                                      FontWeight="Bold"
                                      Background="#AA0B1A2B"
                                      Foreground="White">
                                <MenuItem Header="Star Citizen Česko Slovensko">
                                    <MenuItem Header="Organizace" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/orgs/CZSK" />
                                    <MenuItem Header="Připojit se na náš Discord" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.gg/scczsk" />
                                    <MenuItem Header="Kanál s návody" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1019872713713659965" />
                                    <MenuItem Header="Diskuze k překladu Star Citizen" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1162077785376964719" />
                                    <MenuItem Header="Co je to PTU a jak funguje" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/channels/926921932341919765/1139302959239397446" />
                                    <MenuItem Header="Komunitní mapa hráčů" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.google.com/maps/d/u/2/viewer?mid=1D-N794_RD7wsDt5AayWjf0QJ82fwe0o&amp;hl=cs&amp;ll=49.53699999999999%2C16.512000000000018&amp;z=8" />
                                    <MenuItem Header="Star Citizen CZ/SK Wiki" Command="{Binding OpenUrlCommand}" CommandParameter="https://wiki.theravens.cz/star-citizen/index.php/Hlavn%C3%AD_strana" />
                                    <MenuItem Header="CZ/SK Bar Citizen" Command="{Binding OpenUrlCommand}" CommandParameter="https://barcitizen.star-citizen.cz/" />
                                    <MenuItem Header="Náš Facebook" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.facebook.com/StarCitizenCzSk" />
                                    <MenuItem Header="Náš Youtube" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.youtube.com/c/StarCitizen%C4%8Cesko-Slovensko" />
                                    <MenuItem Header="Anonymní feedback" Command="{Binding OpenUrlCommand}" CommandParameter="https://feedback.star-citizen.cz/" />
                                </MenuItem>

                                <MenuItem Header="Roberts Space Industries">
                                    <MenuItem Header="Můj RSI účet" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/settings" />
                                    <MenuItem Header="Můj RSI hangár" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/pledges" />
                                    <MenuItem Header="Herní balíky" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/store/pledge/browse/game-packages" />
                                    <MenuItem Header="Samostatné lodě" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/pledge/ships" />
                                    <MenuItem Header="Spectrum" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/spectrum/community/SC" />
                                    <MenuItem Header="Issue Council" Command="{Binding OpenUrlCommand}" CommandParameter="https://issue-council.robertsspaceindustries.com/" />
                                    <MenuItem Header="Telemetrie" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/telemetry" />
                                    <MenuItem Header="Stav RSI služeb" Command="{Binding OpenUrlCommand}" CommandParameter="https://status.robertsspaceindustries.com/" />
                                    <MenuItem Header="Plán vývoje" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/roadmap/release-view" />
                                    <MenuItem Header="Financování vývoje" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/funding-goals" />
                                    <MenuItem Header="Hvězdná mapa" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/starmap" />
                                    <MenuItem Header="Tabulka náhradních lodí" Command="{Binding OpenUrlCommand}" CommandParameter="https://support.robertsspaceindustries.com/hc/en-us/articles/360003093114-Loaner-Ship-Matrix" />
                                    <MenuItem Header="Oprava herní postavy" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/reset" />
                                    <MenuItem Header="Kopírovat herní postavu do PTU" Command="{Binding OpenUrlCommand}" CommandParameter="https://robertsspaceindustries.com/account/copy/ptu" />
                                </MenuItem>

                                <MenuItem Header="Nástroje a komunitní weby">
                                    <MenuItem Header="Erkul" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.erkul.games/" />
                                    <MenuItem Header="CCUgame" Command="{Binding OpenUrlCommand}" CommandParameter="https://ccugame.app/" />
                                    <MenuItem Header="UEXcorp" Command="{Binding OpenUrlCommand}" CommandParameter="https://uexcorp.space/" />
                                    <MenuItem Header="Prodej a pronájem lodí ingame" Command="{Binding OpenUrlCommand}" CommandParameter="https://wiki.star-citizen.cz/N%C3%A1kup,_prodej_a_pron%C3%A1jem_lod%C3%AD" />
                                    <MenuItem Header="SC Mission Database" Command="{Binding OpenUrlCommand}" CommandParameter="https://scmdb.net/" />
                                    <MenuItem Header="SC Trade Tools" Command="{Binding OpenUrlCommand}" CommandParameter="https://sc-trade.tools/" />
                                    <MenuItem Header="SC Crafter" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.sccrafter.com/" />
                                    <MenuItem Header="SC Blueprint Finder" Command="{Binding OpenUrlCommand}" CommandParameter="https://scblueprints.app/" />
                                    <MenuItem Header="Hangar" Command="{Binding OpenUrlCommand}" CommandParameter="https://hangar.link/" />
                                    <MenuItem Header="Armory" Command="{Binding OpenUrlCommand}" CommandParameter="https://armory.thespacecoder.space/" />
                                    <MenuItem Header="VerseGuide" Command="{Binding OpenUrlCommand}" CommandParameter="https://verseguide.com/" />
                                    <MenuItem Header="Finder" Command="{Binding OpenUrlCommand}" CommandParameter="https://finder.cstone.space/" />
                                    <MenuItem Header="SC Ships Performances Viewer" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.spviewer.eu/" />
                                    <MenuItem Header="Star Citizen Characters" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.star-citizen-characters.com/" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Background="#AA0B1A2B"
                                Padding="10,4"
                                CornerRadius="6"
                                HorizontalAlignment="Right">
                            <TextBlock Text="{Binding AppVersion}"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="White"
                                       Opacity="0.95"
                                       HorizontalAlignment="Right" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20">
                <ScrollViewer>
                    <StackPanel Spacing="20">

                <!-- Star Citizen Path Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Padding="15"
                        Margin="10"
                        Background="#AA0B1A2B">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Cesta ke Star Citizen" 
                                   Foreground="#F0FFFFFF"
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding InputPath}"
                                     PlaceholderText="Zadejte cestu nebo vyberte složku..."
                                     VerticalContentAlignment="Center"
                                     Height="36" />
                             <Button Grid.Column="1" 
                                     Content="Vybrat složku" 
                                     Command="{Binding BrowseFolderCommand}"
                                     Classes="browse-button"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Margin="10,0,0,0"
                                    Height="36"
                                    Padding="12,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Versions Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Background="#AA0B1A2B">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Informace o verzi" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#F0FFFFFF"/>
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Lokální verze:" 
                                       Foreground="#AAFFFFFF"
                                       FontWeight="Medium"
                                       Margin="0,0,10,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding LocalVersion}"
                                       Foreground="#AAFFFFFF"
                                       Margin="0,0,0,8" />
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Online verze:" 
                                       Foreground="#AAFFFFFF"
                                       FontWeight="Medium"
                                       Margin="0,0,10,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding OnlineVersion}"
                                       Foreground="#AAFFFFFF" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Status:"
                                       Foreground="#AAFFFFFF"
                                       FontWeight="Medium"
                                       Margin="0,8,10,0" />
                            <Border Grid.Row="2" Grid.Column="1"
                                    Background="#CCFFFFFF"
                                    CornerRadius="6"
                                    Padding="8,3"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{Binding StatusBrush}"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Content="Instalovat / Aktualizovat češtinu"
                            Command="{Binding InstallCommand}"
                            HorizontalAlignment="Stretch"
                            Classes="action-primary"
                            Height="40"
                            FontSize="15"
                            Padding="12,6"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />

                    <Button Grid.Column="1"
                            Content="Odinstalovat češtinu"
                            Command="{Binding UninstallCommand}"
                            HorizontalAlignment="Stretch"
                            Classes="action-danger"
                            Height="40"
                            FontSize="15"
                            Padding="12,6"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </Grid>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>

</Window>
