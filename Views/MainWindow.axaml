<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScCestinator.ViewModels"
        x:Class="ScCestinator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SC Češtinátor Linux"
        Width="600"
        Height="260">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10">

            <TextBlock Text="Cesta ke Star Citizen:" />

            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding InputPath}" />
                <Button Grid.Column="1" Content="Vybrat složku"
                        Command="{Binding BrowseFolderCommand}"
                        Margin="5,0,0,0" />
            </Grid>

            <TextBlock Text="{Binding Status}" />

            <TextBlock Text="{Binding LocalVersion, StringFormat=Lokální verze: {0}}" />
            <TextBlock Text="{Binding OnlineVersion, StringFormat=Online verze: {0}}" />

            <Button Content="Instalovat / aktualizovat"
                    IsEnabled="{Binding IsUpdateAvailable}"
                    Command="{Binding InstallCommand}" />

        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding AppVersion}"
                   FontSize="10"
                   Foreground="Gray"
                   HorizontalAlignment="Right"
                   Margin="0,10,0,0" />
    </Grid>

</Window>